# Copy to `.env.local` (or `.env`) and fill in real values. Vite reads
# variables prefixed with VITE_ at *build time* and inlines them into the
# bundle — they are NOT runtime secrets, so don't put anything sensitive
# here. For Docker, these are passed through `build.args` (see Dockerfile +
# docker-compose.yml).

# REST API base URL. Must include the `/api` suffix.
#   - Local dev: http://localhost:5000/api
#   - Docker (compose):  /api  (nginx proxies same-origin to server:5000)
#   - Vercel prod:       https://api.budgetter.lokeshwardewangan.in/api
VITE_BUDGETTER_API_HOST=http://localhost:5000/api

# Landing-page "Get in Touch" form posts to this endpoint (e.g. Formspree,
# Web3Forms, or your own webhook). Leave empty if you don't need the form.
VITE_CONTACT_FORM_HOST_URL=

# Google OAuth Client ID for the "Sign in with Google" button. Same client id
# the server uses on its side as GOOGLE_CLIENT_ID. Get one from
# https://console.cloud.google.com/apis/credentials
VITE_GOOGLE_CLIENT_ID=

# Sentry DSN for browser error tracking. If unset, Sentry.init() no-ops, so
# leaving this blank in dev is fine.
VITE_SENTRY_DSN=
