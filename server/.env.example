# Copy to `.env` and fill in real values. Server validates these at startup
# via Zod (see src/shared/config/env.ts) and refuses to boot if anything is
# missing or malformed.

# Atlas connection string, or `mongodb://mongo:27017/budgetter` if you run
# the docker-compose stack (the `mongo` service is the host).
# MONGO_URL=mongodb+srv://user:pass@cluster.mongodb.net/budgetter?retryWrites=true&w=majority

# Public URLs. SERVER_URL is required (used in OAuth callbacks, OpenAPI spec,
# email links). FRONTEND_URL is optional.
# SERVER_URL=https://api.your-domain.example.com
# FRONTEND_URL=https://your-domain.example.com

# NODE_ENV=production
# PORT=5000



# JWT secrets — generate each with: openssl rand -hex 64
# ACCESS_TOKEN_SECRET_KEY=replace-me
# ACCESS_TOKEN_SECRET_EXPIRY=15m

# ACCOUNT_VERIFICATION_TOKEN_SECRET=replace-me
# ACCOUNT_VERIFICATION_TOKEN_SECRET_EXPIRY=1d

# RESET_PASSWORD_TOKEN_SECRET=replace-me
# RESET_PASSWORD_TOKEN_SECRET_EXPIRY=15m

# Transactional email (Gmail SMTP). GMAIL_PASSKEY = a 16-char Google
# App Password, NOT the account password. https://myaccount.google.com/apppasswords
# ADMIN_GMAIL=your-admin@gmail.com
# GMAIL_PASSKEY=your-gmail-app-password

# Google OAuth — same client id used by the frontend's VITE_GOOGLE_CLIENT_ID
# GOOGLE_CLIENT_ID=your-google-oauth-client-id

# Cloudinary (optional). If unset, avatar uploads will fail at runtime, but
# the server still boots — useful for local dev without media.
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=

# Number of reverse-proxy hops in front of Express. 1 = nginx in docker-compose;
# bump for additional CDN / load-balancer layers so rate-limiting + IP logging
# read the real client IP from X-Forwarded-For.
TRUST_PROXY_HOPS=1

# --- one-shot migration safety flag (NOT loaded by env.ts) ---
# Set when running migrate:v2-* scripts against a non-localhost MONGO_URL.
# Refuses to run without it. Unset after the migration.
# CONFIRM_PROD=yes
