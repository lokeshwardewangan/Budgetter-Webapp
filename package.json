{
  "name": "budgetter",
  "version": "2.0.0",
  "private": true,
  "description": "Personal finance tracker for students — expense logging, monthly reports, and category analytics. React + Vite SPA, Express + Mongoose API.",
  "license": "MIT",
  "author": "Lokeshwar Dewangan",
  "homepage": "https://github.com/lokeshwardewangan/Budgetter-Webapp#readme",
  "bugs": "https://github.com/lokeshwardewangan/Budgetter-Webapp/issues",
  "repository": "github:lokeshwardewangan/Budgetter-Webapp",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "prepare": "husky",
    "dev:client": "npm --prefix client run dev",
    "dev:server": "npm --prefix server run dev",
    "build:client": "npm --prefix client run build",
    "build:server": "npm --prefix server run build",
    "lint": "npm --prefix client run lint",
    "typecheck": "npm --prefix client run typecheck && npm --prefix server run typecheck",
    "test": "npm --prefix server run test",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,css,html,md}\""
  },
  "lint-staged": {
    "client/**/*.{ts,tsx,js,jsx,json,css,html,md}": "prettier --write",
    "server/**/*.{ts,js,json,md}": "prettier --write",
    "*.{json,md,yml,yaml}": "prettier --write"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^15.2.10",
    "prettier": "^3.3.3",
    "prettier-plugin-tailwindcss": "^0.6.11"
  }
}
