# Read by `docker compose`. Copy to `.env` before running.

CLIENT_HOST_PORT=8080

MONGO_INITDB_ROOT_USERNAME=budgetter
MONGO_INITDB_ROOT_PASSWORD=change-me-strong-password
MONGO_INITDB_DATABASE=budgetter

# Override to point at an external cluster (e.g. Atlas).
# MONGO_URL=mongodb+srv://user:pass@cluster.mongodb.net/budgetter?retryWrites=true&w=majority

# Inlined into the SPA bundle at build time. Keep as `/api` so requests go through nginx.
VITE_BUDGETTER_API_HOST=/api
VITE_CONTACT_FORM_HOST_URL=
VITE_GOOGLE_CLIENT_ID=
VITE_SENTRY_DSN=
VITE_BUDGETTER_ADMIN_PASSWORD=
